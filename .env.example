# Replace with your actual Coinflow Merchant ID
NEXT_PUBLIC_MERCHANT_ID=your_merchant_id_here

# Set to 'true' for sandbox/testing, 'false' for production
NEXT_PUBLIC_SANDBOX=true

# nSure partner ID for chargeback protection — use COINFTEST for sandbox
# Production: Coinflow will assign your partnerId
NEXT_PUBLIC_NSURE_PARTNER_ID=COINFTEST

# Coinflow API key (from Merchant Dashboard) — required for create-customer API
# Sandbox: coinflow_sandbox_<your_key> | Prod: coinflow_prod_<your_key>
COINFLOW_API_KEY=
